<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1C1C1E"
    android:padding="16dp"
    android:clipChildren="true"
    android:clipToPadding="true">

    <!-- 1. Left Extract Cover Artwork ImageView -->
    <ImageView
        android:id="@+id/notification_album_art"
        android:layout_width="84dp"
        android:layout_height="84dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:scaleType="centerCrop"
        android:background="#2C2C2E"
        android:contentDescription="Notification Master Exhibit Cover" />

    <!-- 2. Metadata Stack (Title & Artist) -->
    <LinearLayout
        android:id="@+id/notification_metadata_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/notification_album_art"
        android:layout_alignParentTop="true"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/notification_track_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Belong Together"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/notification_artist_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mark Ambor • Uncompromising Lossless"
            android:textColor="#64D2FF"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- 3. Absolute Master Feature: Dedicated Synchronized Ongoing Lockscreen Lyrics Plaque -->
    <TextView
        android:id="@+id/notification_lyrics_line"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/notification_metadata_container"
        android:layout_toEndOf="@id/notification_album_art"
        android:text="&quot;But maybe I should get some rest&quot;"
        android:textColor="#30D158"
        android:textSize="15sp"
        android:textStyle="italic"
        android:singleLine="true"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <!-- 4. Playback Transport hit targets Console -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/notification_lyrics_line"
        android:layout_toEndOf="@id/notification_album_art"
        android:layout_marginStart="16dp"
        android:orientation="horizontal"
        android:gravity="end|center_vertical">

        <ImageButton
            android:id="@+id/notification_action_prev"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#FFFFFF"
            android:contentDescription="Previous Release Track" />

        <ImageButton
            android:id="@+id/notification_action_play_pause"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/notification_play_circle"
            android:src="@android:drawable/ic_media_play"
            android:tint="#000000"
            android:elevation="4dp"
            android:contentDescription="Toggle Audio Play/Pause" />

        <ImageButton
            android:id="@+id/notification_action_next"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_next"
            android:tint="#FFFFFF"
            android:contentDescription="Next Master Master Release" />

    </LinearLayout>

</RelativeLayout>
