<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_glass_background"
    android:padding="16dp">

    <!-- 1. Left Extract Cover Artwork ImageView -->
    <ImageView
        android:id="@+id/widget_album_art"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:scaleType="centerCrop"
        android:background="#2C2C2E"
        android:contentDescription="Widget Master Exhibit Cover" />

    <!-- Codec Corner Foil Seal directly on widget art -->
    <TextView
        android:id="@+id/widget_codec_seal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBottom="@id/widget_album_art"
        android:layout_alignEnd="@id/widget_album_art"
        android:layout_margin="4dp"
        android:background="#E6000000"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="FLAC"
        android:textColor="#64D2FF"
        android:textSize="9sp"
        android:fontFamily="monospace"
        android:textStyle="bold" />

    <!-- 2. Metadata Stack (Title & Artist) -->
    <LinearLayout
        android:id="@+id/widget_metadata_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/widget_album_art"
        android:layout_alignParentTop="true"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_track_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Belong Together"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_artist_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mark Ambor • Uncompromising Master"
            android:textColor="#D1D1D6"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- 3. Absolute Master Feature: Ongoing Synchronized Real-Time Lyrics Phrase on Home Screen Widget -->
    <TextView
        android:id="@+id/widget_lyrics_line"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_metadata_container"
        android:layout_toEndOf="@id/widget_album_art"
        android:text="&quot;But maybe I should get some rest&quot;"
        android:textColor="#30D158"
        android:textSize="14sp"
        android:textStyle="italic"
        android:singleLine="true"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <!-- 4. Playback Transport hit targets Console -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_lyrics_line"
        android:layout_toEndOf="@id/widget_album_art"
        android:layout_marginStart="16dp"
        android:orientation="horizontal"
        android:gravity="end|center_vertical">

        <ImageButton
            android:id="@+id/widget_action_prev"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#FFFFFF"
            android:contentDescription="Previous Track" />

        <ImageButton
            android:id="@+id/widget_action_play_pause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/widget_play_circle"
            android:src="@android:drawable/ic_media_play"
            android:tint="#000000"
            android:elevation="4dp"
            android:contentDescription="Toggle Audio Play/Pause" />

        <ImageButton
            android:id="@+id/widget_action_next"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_next"
            android:tint="#FFFFFF"
            android:contentDescription="Next Master Release" />

    </LinearLayout>

</RelativeLayout>
